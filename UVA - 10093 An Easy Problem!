#include <stdio.h>
#include <string.h>

int value(char c) {
    if (c >= '0' && c <= '9') {
        return c - '0';
    }

    if (c >= 'A' && c <= 'Z') {
        return c - 'A' + 10;
    }

    if (c >= 'a' && c <= 'z') {
        return c - 'a' + 36;
    }

    return -1;
}

int main() {
    char s[10000];

    while (scanf("%s", s) != EOF) {
        int sum = 0;
        int maxDigit = 0;
        int i;

        for (i = 0; s[i] != '\0'; i++) {
            int v = value(s[i]);

            if (v >= 0) {
                sum += v;

                if (v > maxDigit) {
                    maxDigit = v;
                }
            }
        }

        int base = maxDigit + 1;

        if (base < 2) {
            base = 2;
        }

        int found = 0;

        for (; base <= 62; base++) {
            if (sum % (base - 1) == 0) {
                printf("%d\n", base);
                found = 1;
                break;
            }
        }

        if (!found) {
            printf("such number is impossible!\n");
        }
    }

    return 0;
}
