#include <iostream>
#include <map>
#include <string>
#include <iomanip>
using namespace std;

int main() {
    int T;
    string line;

    cin >> T;
    getline(cin, line); 
    getline(cin, line); 

    for (int tc = 1; tc <= T; tc++) {
        map<string, int> tree;
        int total = 0;

        while (getline(cin, line)) {
            if (line == "") {
                break;
            }

            tree[line]++;
            total++;
        }

        if (tc > 1) {
            cout << endl;
        }

        for (map<string, int>::iterator it = tree.begin(); it != tree.end(); it++) {
            double percent = (double)it->second / total * 100.0;

            cout << it->first << " ";
            cout << fixed << setprecision(4) << percent << endl;
        }
    }

    return 0;
}
