#include <stdio.h>

int cost[36];

int calcCost(long long num, int base) {
    int total = 0;

    if (num == 0) {
        return cost[0];
    }

    while (num > 0) {
        int digit = num % base;
        total += cost[digit];
        num /= base;
    }

    return total;
}

int main() {
    int T;
    scanf("%d", &T);

    int tc;

    for (tc = 1; tc <= T; tc++) {
        int i;

        for (i = 0; i < 36; i++) {
            scanf("%d", &cost[i]);
        }

        int Q;
        scanf("%d", &Q);

        printf("Case %d:\n", tc);

        while (Q--) {
            long long num;
            scanf("%lld", &num);

            int minCost = 2147483647;
            int baseCost[37];

            int base;
            for (base = 2; base <= 36; base++) {
                baseCost[base] = calcCost(num, base);

                if (baseCost[base] < minCost) {
                    minCost = baseCost[base];
                }
            }

            printf("Cheapest base(s) for number %lld:", num);

            for (base = 2; base <= 36; base++) {
                if (baseCost[base] == minCost) {
                    printf(" %d", base);
                }
            }

            printf("\n");
        }

        if (tc != T) {
            printf("\n");
        }
    }

    return 0;
}
