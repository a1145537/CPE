#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    int doom[13] = {0, 10, 21, 0, 4, 9, 6, 11, 8, 5, 10, 7, 12};

    char week[7][10] = {
        "Monday", "Tuesday", "Wednesday", "Thursday",
        "Friday", "Saturday", "Sunday"
    };

    while (T--) {
        int M, D;
        scanf("%d %d", &M, &D);

        int diff = D - doom[M];

        int ans = (diff % 7 + 7) % 7;

        printf("%s\n", week[ans]);
    }

    return 0;
}
