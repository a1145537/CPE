#include <stdio.h>
#include <stdlib.h>

static int gM;
static int is_odd(int x) {
    return (x % 2) != 0;
}

static int cmp(const void *pa, const void *pb) {
    int a = *(const int *)pa;
    int b = *(const int *)pb;

    int ra = a % gM;
    int rb = b % gM;

    if (ra != rb) {
        return (ra < rb) ? -1 : 1;
    }
    {
        int oa = is_odd(a);
        int ob = is_odd(b);

        if (oa != ob) return oa ? -1 : 1;

        if (oa) {
            if (a == b) return 0;
            return (a > b) ? -1 : 1;
        } else {
            if (a == b) return 0;
            return (a < b) ? -1 : 1;
        }
    }
}

int main(void) {
    int N, M;

    while (scanf("%d %d", &N, &M) == 2) {
        if (N == 0 && M == 0) {
            printf("0 0\n");
            break;
        }

        printf("%d %d\n", N, M);
        gM = M;

        {
            int *arr = (int *)malloc(sizeof(int) * N);
            int i;

            for (i = 0; i < N; i++) {
                scanf("%d", &arr[i]);
            }

            qsort(arr, (size_t)N, sizeof(int), cmp);

            for (i = 0; i < N; i++) {
                printf("%d\n", arr[i]);
            }

            free(arr);
        }
    }

    return 0;
}
