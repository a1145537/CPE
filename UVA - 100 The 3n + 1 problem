#include <stdio.h>

int main(void) {
    int a, b;

    
    while (scanf("%d %d", &a, &b) == 2) {
        int i, n;
        int max = 0;  

        printf("%d %d", a, b);  

        
        int start = a, end = b;
        if (a > b) {
            start = b;
            end = a;
        }

       
        for (i = start; i <= end; i++) {
            n = i;
            int count = 1; 

            while (n != 1) {
                if (n % 2 == 1)
                    n = 3 * n + 1;
                else
                    n = n / 2;
                count++; 
            }

            if (count > max)
                max = count;
        }

        printf(" %d\n", max);
    }

    return 0;
}
