#include <stdio.h>

int main() {
    int n;

    while (scanf("%d", &n) != EOF) {
        if (n == 0) {
            break;
        }

        int bits[40];
        int len = 0;
        int count = 0;
        int temp = n;

        while (temp > 0) {
            bits[len] = temp % 2;

            if (bits[len] == 1) {
                count++;
            }

            len++;
            temp /= 2;
        }

        printf("The parity of ");

        int i;
        for (i = len - 1; i >= 0; i--) {
            printf("%d", bits[i]);
        }

        printf(" is %d (mod 2).\n", count);
    }

    return 0;
}
