#include <stdio.h>
#include <string.h>

int main() {
    int n;

    while (scanf("%d", &n) != EOF) {
        if (n == 0) {
            break;
        }

        int top = 1, bottom = 6;
        int north = 2, south = 5;
        int west = 3, east = 4;

        char cmd[10];
        int i;

        for (i = 0; i < n; i++) {
            scanf("%s", cmd);

            int temp;

            if (strcmp(cmd, "north") == 0) {
                temp = top;
                top = south;
                south = bottom;
                bottom = north;
                north = temp;
            } else if (strcmp(cmd, "south") == 0) {
                temp = top;
                top = north;
                north = bottom;
                bottom = south;
                south = temp;
            } else if (strcmp(cmd, "east") == 0) {
                temp = top;
                top = west;
                west = bottom;
                bottom = east;
                east = temp;
            } else if (strcmp(cmd, "west") == 0) {
                temp = top;
                top = east;
                east = bottom;
                bottom = west;
                west = temp;
            }
        }

        printf("%d\n", top);
    }

    return 0;
}
