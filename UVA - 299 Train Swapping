#include <stdio.h>

int main(void) {
    int T;
    scanf("%d", &T);

    while (T--) {
        int L;
        scanf("%d", &L);

        int a[55];
        int i, j;

        for (i = 0; i < L; i++) {
            scanf("%d", &a[i]);
        }

        int swaps = 0;

        for (i = 0; i < L; i++) {
            for (j = 0; j < L - 1; j++) {
                if (a[j] > a[j + 1]) {
                    int tmp = a[j];
                    a[j] = a[j + 1];
                    a[j + 1] = tmp;
                    swaps++;
                }
            }
        }

        printf("Optimal train swapping takes %d swaps.\n", swaps);
    }

    return 0;
}
