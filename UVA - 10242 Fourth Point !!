#include <stdio.h>
#include <math.h>

int same(double x1, double y1, double x2, double y2) {
    return fabs(x1 - x2) < 1e-9 && fabs(y1 - y2) < 1e-9;
}

int main() {
    double x1, y1, x2, y2, x3, y3, x4, y4;

    while (scanf("%lf %lf %lf %lf %lf %lf %lf %lf",
                 &x1, &y1, &x2, &y2, &x3, &y3, &x4, &y4) != EOF) {

        double ansX, ansY;

        if (same(x1, y1, x3, y3)) {
            ansX = x2 + x4 - x1;
            ansY = y2 + y4 - y1;
        } else if (same(x1, y1, x4, y4)) {
            ansX = x2 + x3 - x1;
            ansY = y2 + y3 - y1;
        } else if (same(x2, y2, x3, y3)) {
            ansX = x1 + x4 - x2;
            ansY = y1 + y4 - y2;
        } else {
            ansX = x1 + x3 - x2;
            ansY = y1 + y3 - y2;
        }

        printf("%.3lf %.3lf\n", ansX, ansY);
    }

    return 0;
}
