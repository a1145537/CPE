#include <stdio.h>
#include <math.h>

int main() {
    int a, b;

    while (scanf("%d %d", &a, &b) != EOF) {
        if (a == 0 && b == 0) {
            break;
        }

        int count = 0;
        int i;

        for (i = 1; i * i <= b; i++) {
            if (i * i >= a) {
                count++;
            }
        }

        printf("%d\n", count);
    }

    return 0;
}
