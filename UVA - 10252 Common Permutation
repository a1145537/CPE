#include <stdio.h>
#include <string.h>

int main() {
    char a[1005], b[1005];
    int ca[26], cb[26];
    int i, j;

    while (gets(a) && gets(b)) {
        for (i = 0; i < 26; i++) {
            ca[i] = 0;
            cb[i] = 0;
        }

        for (i = 0; a[i] != '\0'; i++) {
            ca[a[i] - 'a']++;
        }

        for (i = 0; b[i] != '\0'; i++) {
            cb[b[i] - 'a']++;
        }

        for (i = 0; i < 26; i++) {
            int m = ca[i] < cb[i] ? ca[i] : cb[i];
            for (j = 0; j < m; j++) {
                putchar('a' + i);
            }
        }

        putchar('\n');
    }

    return 0;
}
