#include <stdio.h>

int main() {
    int fib[50];
    int count = 0;
    int T;
    int n, original;
    int i, started;

    fib[0] = 1;
    fib[1] = 2;
    count = 2;

    while (1) {
        fib[count] = fib[count - 1] + fib[count - 2];
        if (fib[count] > 100000000) {
            break;
        }
        count++;
    }

    scanf("%d", &T);

    while (T--) {
        scanf("%d", &n);
        original = n;
        started = 0;

        printf("%d = ", original);

        for (i = count - 1; i >= 0; i--) {
            if (fib[i] <= n) {
                printf("1");
                n -= fib[i];
                started = 1;
            } else if (started) {
                printf("0");
            }
        }

        printf(" (fib)\n");
    }

    return 0;
}
