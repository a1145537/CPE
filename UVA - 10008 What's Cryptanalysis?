#include <stdio.h>
#include <ctype.h>

typedef struct {
    char ch;
    int cnt;
} Node;

int cmp(Node a, Node b) {
    if (a.cnt != b.cnt) return b.cnt - a.cnt;
    return a.ch - b.ch;
}

int main() {
    int n;
    int count[26] = {0};
    char line[300];
    Node arr[26];
    Node tmp;
    int i, j, k;

    scanf("%d\n", &n);

    while (n--) {
        fgets(line, sizeof(line), stdin);
        for (i = 0; line[i] != '\0'; i++) {
            if (isalpha((unsigned char)line[i])) {
                count[toupper((unsigned char)line[i]) - 'A']++;
            }
        }
    }

    k = 0;
    for (i = 0; i < 26; i++) {
        if (count[i] > 0) {
            arr[k].ch = 'A' + i;
            arr[k].cnt = count[i];
            k++;
        }
    }

    for (i = 0; i < k - 1; i++) {
        for (j = i + 1; j < k; j++) {
            if (cmp(arr[i], arr[j]) > 0) {
                tmp = arr[i];
                arr[i] = arr[j];
                arr[j] = tmp;
            }
        }
    }

    for (i = 0; i < k; i++) {
        printf("%c %d\n", arr[i].ch, arr[i].cnt);
    }

    return 0;
}
