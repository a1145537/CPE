#include <stdio.h>
#include <stdlib.h>

int cmp(const void *a, const void *b) {
    return (*(int *)a) - (*(int *)b);
}

int main(void) {
    int n;

    while (scanf("%d", &n) == 1) {
        int *arr = (int *)malloc(sizeof(int) * n);
        int i;

        for (i = 0; i < n; i++) {
            scanf("%d", &arr[i]);
        }

        qsort(arr, n, sizeof(int), cmp);

        
        int L = arr[(n - 1) / 2];
        int U = arr[n / 2];

        int count = 0;
        for (i = 0; i < n; i++) {
            if (arr[i] >= L && arr[i] <= U)
                count++;
        }

        printf("%d %d %d\n", L, count, U - L + 1);

        free(arr);
    }

    return 0;
}
