#include <stdio.h>
#pragma warning(suppress:4996) 
int main(void) {
	int t;
	scanf("%d", &t);
	while (t--) {
		int r,i,j;
		scanf("%d", &r);
		int a[505];
		for (i = 0; i < r; i++) {
			scanf("%d", &a[i]);
		}
		for ( i = 0; i < r - 1; i++) {
			for ( j = 0; j < r - 1 - i; j++) {
				if (a[j] > a[j + 1]) {
					int temp = a[j];
					a[j] = a[j + 1];
					a[j + 1] = temp;
				}
			}
		}
		int median = a[r / 2];

		int sum = 0;
		for (i = 0; i < r; i++) {
			int d = a[i] - median;
			if (d < 0) d = -d;  
			sum += d;
		}
        printf("%d\n", sum);
	}
	

}
