#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    int tc;
    for (tc = 1; tc <= T; tc++) {
        int n;
        scanf(" N = %d", &n);

        long long a[105][105];
        int ok = 1;

        int i, j;

        for (i = 0; i < n; i++) {
            for (j = 0; j < n; j++) {
                scanf("%lld", &a[i][j]);

                if (a[i][j] < 0) {
                    ok = 0;
                }
            }
        }

        for (i = 0; i < n; i++) {
            for (j = 0; j < n; j++) {
                if (a[i][j] != a[n - 1 - i][n - 1 - j]) {
                    ok = 0;
                }
            }
        }

        if (ok) {
            printf("Test #%d: Symmetric.\n", tc);
        } else {
            printf("Test #%d: Non-symmetric.\n", tc);
        }
    }

    return 0;
}
