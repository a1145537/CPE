#include <stdio.h>

int isPrime(int n) {
    int i;

    if (n < 2) {
        return 0;
    }

    for (i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            return 0;
        }
    }

    return 1;
}

int reverseNumber(int n) {
    int rev = 0;

    while (n > 0) {
        rev = rev * 10 + n % 10;
        n /= 10;
    }

    return rev;
}

int main() {
    int n;

    while (scanf("%d", &n) != EOF) {
        int rev = reverseNumber(n);

        if (!isPrime(n)) {
            printf("%d is not prime.\n", n);
        } else if (rev != n && isPrime(rev)) {
            printf("%d is emirp.\n", n);
        } else {
            printf("%d is prime.\n", n);
        }
    }

    return 0;
}
