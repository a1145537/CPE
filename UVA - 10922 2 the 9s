#include <stdio.h>
#include <string.h>

int main() {
    char n[1100];

    while (scanf("%s", n)) {
        if (strcmp(n, "0") == 0) break;

        int sum = 0;
        int i;  

        for (i = 0; n[i]; i++) {
            sum += n[i] - '0';
        }

        if (sum % 9 != 0) {
            printf("%s is not a multiple of 9.\n", n);
            continue;
        }

        int degree = 1;
        while (sum >= 10) {
            int temp = 0;
            while (sum > 0) {
                temp += sum % 10;
                sum /= 10;
            }
            sum = temp;
            degree++;
        }

        printf("%s is a multiple of 9 and has 9-degree %d.\n", n, degree);
    }

    return 0;
}
