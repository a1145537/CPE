#include <stdio.h>
#include <string.h>

typedef struct {
    int ascii;
    int freq;
} CharInfo;

int main() {
    char line[1005];
    int first = 1;

    while (fgets(line, sizeof(line), stdin) != NULL) {
        int count[128] = {0};
        CharInfo arr[128];
        int len = strlen(line);
        int n = 0;

        int i, j;

        for (i = 0; i < len; i++) {
            if (line[i] == '\n' || line[i] == '\r') {
                continue;
            }

            count[(int)line[i]]++;
        }

        for (i = 0; i < 128; i++) {
            if (count[i] > 0) {
                arr[n].ascii = i;
                arr[n].freq = count[i];
                n++;
            }
        }

        for (i = 0; i < n - 1; i++) {
            for (j = i + 1; j < n; j++) {
                if (arr[i].freq > arr[j].freq ||
                    (arr[i].freq == arr[j].freq && arr[i].ascii < arr[j].ascii)) {
                    CharInfo temp = arr[i];
                    arr[i] = arr[j];
                    arr[j] = temp;
                }
            }
        }

        if (!first) {
            printf("\n");
        }
        first = 0;

        for (i = 0; i < n; i++) {
            printf("%d %d\n", arr[i].ascii, arr[i].freq);
        }
    }

    return 0;
}
