#include <stdio.h>

int main(void) {
    int n;
    int a[3005];
    int seen[3005];
    int i;

    while (scanf("%d", &n) == 1) {

        for (i = 0; i < n; i++) {
            scanf("%d", &a[i]);
        }

        if (n == 1) {
            printf("Jolly\n");
            continue;
        }

        for (i = 0; i <= n - 1; i++) {
            seen[i] = 0;
        }

        for (i = 1; i < n; i++) {
            int d = a[i] - a[i - 1];
            if (d < 0) {
                d = -d;
            }

            if (d >= 1 && d <= n - 1) {
                seen[d] = 1;
            }
            else {
                seen[0] = 1; 
            }
        }

        if (seen[0] == 1) {
            printf("Not jolly\n");
        }
        else {
            int ok = 1;
            for (i = 1; i <= n - 1; i++) {
                if (seen[i] == 0) {
                    ok = 0;
                    break;
                }
            }
            if (ok) {
                printf("Jolly\n");
            }
            else {
                printf("Not jolly\n");
            }
        }
    }

    return 0;
}
