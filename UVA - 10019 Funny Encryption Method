#include <stdio.h>

int countOne(int n) {
    int count = 0;

    while (n > 0) {
        if (n % 2 == 1) {
            count++;
        }

        n /= 2;
    }

    return count;
}

int main() {
    int T;
    scanf("%d", &T);

    while (T--) {
        char s[20];
        int dec, hex;

        scanf("%s", s);

        sscanf(s, "%d", &dec);
        sscanf(s, "%x", &hex);

        printf("%d %d\n", countOne(dec), countOne(hex));
    }

    return 0;
}
